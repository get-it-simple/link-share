{
	"name": "links-share-storage",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "npm run lint && vite build",
		"lint": "eslint . --ext ts,tsx --max-warnings=0",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier \"src/**/*.{ts,tsx,css,md}\" --write",
		"preview": "vite preview",
		"predeploy": "npm run build",
		"deploy": "npm run predeploy && npx gh-pages -d dist"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.18",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/react": "^18.3.4",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"autoprefixer": "^10.4.20",
		"gh-pages": "^6.1.1",
		"postcss": "^8.4.41",
		"tailwindcss": "^3.4.10",
		"typescript": "^5.5.4",
		"typescript-eslint": "^8.48.0",
		"vite": "^5.4.2",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24"
	}
}
